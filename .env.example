# Backend
APP_ENV=development
HTTP_ADDR=:8080
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/sauna?sslmode=disable
REDIS_URL=redis://127.0.0.1:16379/0
SAUNA_SECRET_KEY=change-me-to-a-long-random-secret
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://sauna.wrenzeal.top

# Optional platform trial provider for anonymous public-agent trials
PLATFORM_PROVIDER_BASE_URL=
PLATFORM_PROVIDER_API_KEY=
PLATFORM_CHAT_MODEL=

# Frontend
NEXT_PUBLIC_SAUNA_API_BASE_URL=http://127.0.0.1:8080/api/v1
SAUNA_BACKEND_INTERNAL_URL=http://127.0.0.1:8080
