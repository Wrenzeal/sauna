# Backend
APP_ENV=development
HTTP_ADDR=:19588
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/sauna?sslmode=disable
REDIS_URL=redis://127.0.0.1:16379/0
SAUNA_SECRET_KEY=change-me-to-a-long-random-secret
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://sauna.wrenzeal.top

# Auth email verification
# development defaults to AUTH_EMAIL_DRIVER=dev and prints the code in API response/logs.
# production defaults to AUTH_EMAIL_DRIVER=smtp and requires SMTP_* values.
AUTH_EMAIL_DRIVER=dev
EMAIL_CODE_TTL=10m
AUTH_EMAIL_LIMIT_PER_HOUR=5
AUTH_IP_LIMIT_PER_HOUR=20
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_FROM_NAME=Sauna
SMTP_SECURITY=auto
SMTP_TIMEOUT=15s

# Frontend
NEXT_PUBLIC_SAUNA_API_BASE_URL=http://127.0.0.1:19588/api/v1
SAUNA_BACKEND_INTERNAL_URL=http://127.0.0.1:19588
